{
  "entities": {
    "Channel": {
      "title": "TV Channel",
      "description": "A live sports TV channel",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "sport": { "type": "string", "enum": ["Football", "Cricket", "NBA", "Tennis", "General"] },
        "country": { "type": "string" },
        "logo": { "type": "string", "format": "uri" },
        "type": { "type": "string", "enum": ["iframe", "youtube", "m3u8"] },
        "source": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Offline"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "sport", "type", "source", "status"]
    },
    "Match": {
      "title": "Sports Match",
      "description": "An upcoming or live sports match",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "teamA": { "type": "string" },
        "teamB": { "type": "string" },
        "teamALogo": { "type": "string" },
        "teamBLogo": { "type": "string" },
        "sport": { "type": "string" },
        "tournament": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Upcoming", "Live", "Finished"] },
        "channelId": { "type": "string" },
        "scoreA": { "type": "string" },
        "scoreB": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "aiPrediction": {
          "type": "object",
          "properties": {
            "teamAProb": { "type": "number" },
            "teamBProb": { "type": "number" },
            "drawProb": { "type": "number" },
            "reason": { "type": "string" }
          }
        },
        "votesA": { "type": "number" },
        "votesB": { "type": "number" },
        "votesDraw": { "type": "number" }
      },
      "required": ["teamA", "teamB", "sport", "date", "status"]
    },
    "SliderItem": {
      "title": "Hero Slider Item",
      "description": "An item for the homepage hero carousel",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "link": { "type": "string" },
        "order": { "type": "number" },
        "isActive": { "type": "boolean" }
      },
      "required": ["title", "image", "isActive"]
    },
    "Highlight": {
      "title": "Match Highlight",
      "description": "Video highlights of a finished match",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "thumbnail": { "type": "string", "format": "uri" },
        "videoUrl": { "type": "string" },
        "category": { "type": "string" },
        "duration": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "thumbnail", "videoUrl", "category"]
    },
    "News": {
      "title": "Sports News",
      "description": "AI-generated and manual news articles",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "content": { "type": "string" },
        "excerpt": { "type": "string" },
        "metaTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["Draft", "Scheduled", "Published", "Archived"] },
        "type": { "type": "string" },
        "country": { "type": "string" },
        "tone": { "type": "string" },
        "publishDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "allowComments": { "type": "boolean" },
        "isFeatured": { "type": "boolean" }
      },
      "required": ["title", "slug", "category", "content", "status"]
    },
    "AdConfig": {
      "title": "Global Ad Configuration",
      "description": "Configurations for ad placements across the site",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "topBanner": { "type": "string" },
        "insideArticle1": { "type": "string" },
        "insideArticle2": { "type": "string" },
        "sidebar": { "type": "string" },
        "footer": { "type": "string" }
      }
    },
    "Widget": {
      "title": "External Widget",
      "description": "HTML/JS embed code for external widgets",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "htmlCode": { "type": "string" },
        "placement": { "type": "string", "enum": ["HomeSidebar", "LiveScore", "MatchDetails", "Footer"] }
      },
      "required": ["name", "htmlCode", "placement"]
    },
    "Ad": {
      "title": "Advertisement",
      "description": "Ad code for monetization",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "placement": { "type": "string", "enum": ["Header", "Sidebar", "Player", "Footer"] },
        "code": { "type": "string" }
      },
      "required": ["name", "placement", "code"]
    },
    "NavigationItem": {
      "title": "Navigation Menu",
      "description": "Customizable main navigation menu items",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "path": { "type": "string" },
        "order": { "type": "number" },
        "submenu": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "path": { "type": "string" }
            },
            "required": ["name", "path"]
          }
        }
      },
      "required": ["name", "path", "order"]
    },
    "Subscriber": {
      "title": "Newsletter Subscriber",
      "description": "Subscriber emails for newsletter",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "/channels/{channelId}": { "schema": "Channel", "description": "Collection of TV channels" },
    "/matches/{matchId}": { "schema": "Match", "description": "Collection of sports matches" },
    "/highlights/{highlightId}": { "schema": "Highlight", "description": "Collection of video highlights" },
    "/news/{newsId}": { "schema": "News", "description": "Collection of news articles" },
    "/adConfigs/{configId}": { "schema": "AdConfig", "description": "Global ad configurations" },
    "/widgets/{widgetId}": { "schema": "Widget", "description": "Collection of site widgets" },
    "/ads/{adId}": { "schema": "Ad", "description": "Collection of advertisements" },
    "/sliders/{sliderId}": { "schema": "SliderItem", "description": "Collection of hero slider items" },
    "/navigation/{navId}": { "schema": "NavigationItem", "description": "Collection of navigation menu items" },
    "/subscribers/{subId}": { "schema": "Subscriber", "description": "Collection of newsletter subscribers" },
    "/matches/{matchId}/commentary/{commentId}": {
      "schema": {
        "type": "object",
        "properties": {
          "minute": { "type": "string" },
          "text": { "type": "string" },
          "type": { "type": "string", "enum": ["goal", "card", "info", "substitution"] },
          "timestamp": { "type": "number" }
        },
        "required": ["minute", "text", "type", "timestamp"]
      },
      "description": "Play-by-play commentary for a specific match"
    },
    "/matches/{matchId}/chat/{messageId}": {
      "schema": {
        "type": "object",
        "properties": {
          "username": { "type": "string" },
          "text": { "type": "string" },
          "userId": { "type": "string" },
          "userAvatar": { "type": "string" },
          "timestamp": { "type": "number" },
          "isAdmin": { "type": "boolean" }
        },
        "required": ["username", "text", "userId", "timestamp"]
      },
      "description": "Real-time fan discussion message for a specific match"
    },
    "/admins/{adminId}": { "schema": { "type": "object", "properties": { "email": { "type": "string" } } }, "description": "Whitelist of admin UIDs" }
  }
}
